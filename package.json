{
  "name": "duydodee-streaming",
  "version": "2.0.0",
  "description": "DUYDODEE Streaming Platform - ดูซีรีส์ออนไลน์ฟรี",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "node build.js",
    "build:client": "node build.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "format": "prettier --write src/",
    "clean": "rimraf public/build/ node_modules/",
    "logs": "if not exist logs mkdir logs",
    "prestart": "npm run logs",
    "prepare": "husky install"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "googleapis": "^171.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "supertest": "^7.2.2"
  },
  "lint-staged": {
    "*.js": "eslint --fix",
    "*.{js,css,md}": "prettier --write"
  },
  "keywords": [
    "streaming",
    "series",
    "thai",
    "nodejs",
    "express",
    "javascript"
  ],
  "author": "DUYDOO-DEE",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
